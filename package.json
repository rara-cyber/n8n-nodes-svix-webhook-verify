      "dist/credentials/SvixWebhookApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/SvixWebhookVerify/SvixWebhookVerify.node.js"
    ]
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "dependencies": {},
  "devDependencies": {
    "@n8n/node-cli": "*",
    "@types/node": "^24.0.1",
    "eslint": "^9.32.0",
    "gulp": "^4.0.2",
    "typescript": "5.9.2"
  }
}
